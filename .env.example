# Copiar a .env.local y completar con los valores del proyecto Supabase
# (Project Settings -> API). La anon key es publica, queda protegida por RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Clave publica VAPID para notificaciones push. La privada va como secret de
# Edge Functions (npx supabase secrets set), nunca en este archivo.
VITE_VAPID_PUBLIC_KEY=
